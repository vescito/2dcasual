    m_Metadata:
      m_Items: []
  - m_Id: 3068867375104
    m_Localized: "Zp\u011Bt"
    m_Metadata:
      m_Items: []
  - m_Id: 3148932444160
    m_Localized: "Podr\u017Ete a p\u0159et\xE1hn\u011Bte gran\xE1ty na praku a uvoln\u011Bte
      tak, abyste zas\xE1hli padaj\xEDc\xED rakety. Pokud raketa dopadne na zem,
      hra skon\u010Dila. Pokuste se p\u0159ekonat sv\u016Fj nejlep\u0161\xED v\xFDsledek
      a sta\u0148te se mistrem Grenade Sling!"
    m_Metadata:
      m_Items: []
  - m_Id: 3406093611008
    m_Localized: 'Pauza

'
    m_Metadata:
      m_Items: []
  - m_Id: 3496027877376
    m_Localized: "Hlavn\xED nab\xEDdka "
    m_Metadata:
      m_Items: []
  - m_Id: 3579335143424
    m_Localized: "Pokra\u010Dovat"
    m_Metadata:
      m_Items: []
  - m_Id: 3697144754176
    m_Localized: Konec hry
    m_Metadata:
      m_Items: []
  - m_Id: 3796453289984
    m_Localized: "Sk\xF3re:"
    m_Metadata:
      m_Items: []
  - m_Id: 3868268163072
    m_Localized: "Opravdu chcete zp\u011Bt do hlavn\xED nab\xEDdky? V\xE1\u0161 pokrok
      bude ztracen."
    m_Metadata:
      m_Items: []
