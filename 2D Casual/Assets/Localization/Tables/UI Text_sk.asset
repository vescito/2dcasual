  m_TableData:
  - m_Id: 50910457856
    m_Localized: "Ako hra\u0165"
    m_Metadata:
      m_Items: []
  - m_Id: 2334402801664
    m_Localized: "Najvy\u0161\u0161ie sk\xF3re:"
    m_Metadata:
      m_Items: []
  - m_Id: 2527202373632
    m_Localized: Autori
    m_Metadata:
      m_Items: []
  - m_Id: 2688423030784
    m_Localized: "Vytvoril:\r"
    m_Metadata:
      m_Items: []
  - m_Id: 2787861590016
    m_Localized: "Hudba:\r"
    m_Metadata:
      m_Items: []
  - m_Id: 2953641455616
    m_Localized: "P\xEDsmo:"
    m_Metadata:
      m_Items: []
  - m_Id: 3068867375104
    m_Localized: "Sp\xE4\u0165"
    m_Metadata:
      m_Items: []
  - m_Id: 3148932444160
    m_Localized: "Podr\u017Ete a potiahnite gran\xE1ty na praku a uvo\u013Enite ich,
      aby ste zasiahli padaj\xFAce rakety. Ak raketa dopadne na zem, hra sa skon\u010Dila.
      Pok\xFAste sa prekona\u0165 svoj najlep\u0161\xED v\xFDsledok a sta\u0148te
      sa \u0161ampi\xF3nom Grenade Sling!"
    m_Metadata:
      m_Items: []
  - m_Id: 3406093611008
    m_Localized: Pauza
    m_Metadata:
      m_Items: []
  - m_Id: 3496027877376
    m_Localized: "Hlavn\xE9 menu"
    m_Metadata:
      m_Items: []
  - m_Id: 3579335143424
    m_Localized: "Pokra\u010Dova\u0165"
    m_Metadata:
      m_Items: []
  - m_Id: 3697144754176
    m_Localized: Koniec hry
    m_Metadata:
      m_Items: []
  - m_Id: 3796453289984
    m_Localized: "Sk\xF3re:"
    m_Metadata:
      m_Items: []
  - m_Id: 3868268163072
    m_Localized: "Naozaj sa chcete vr\xE1ti\u0165 do hlavn\xE9ho menu? V\xE1\u0161
      pokrok sa strat\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 4043019644928
    m_Localized: "\xC1no\r"
    m_Metadata:
      m_Items: []
  - m_Id: 4129053208576
    m_Localized: Nie
    m_Metadata:
      m_Items: []
  - m_Id: 8548247400448
    m_Localized: "Hra\u0165 znova"
    m_Metadata:
      m_Items: []
